{
    "name": "core-crypto",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git@github.com:wireapp/core-crypto.git"
    },
    "type": "module",
    "workspaces": [
        "packages/core-crypto",
        "packages/browser",
        "packages/native"
    ],
    "imports": {
        "#core-crypto-ffi": {
            "cc-browser": "./packages/browser/src/autogenerated/core_crypto_ffi.ts",
            "cc-native": "./packages/native/src/autogenerated/index.ts",
            "default": "./packages/browser/src/autogenerated/core_crypto_ffi.ts"
        },
        "#core-crypto": {
            "cc-browser": "@wireapp/core-crypto/browser",
            "cc-native": "@wireapp/core-crypto/native",
            "default": "@wireapp/core-crypto/browser"
        },
        "#shared-utils": {
            "cc-browser": "./packages/browser/shared/utils.ts",
            "cc-native": "./packages/native/shared/utils.ts",
            "default": "./packages/browser/shared/utils.ts"
        }
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bun": "^1.3.14",
        "@types/chai": "^5.2.3",
        "@types/mocha": "^10.0.10",
        "@types/node": "^26.1.1",
        "@wdio/browser-runner": "^9.29.1",
        "@wdio/cli": "^9.29.1",
        "@wdio/logger": "^9.29.1",
        "@wdio/mocha-framework": "^9.29.1",
        "@wdio/spec-reporter": "^9.29.1",
        "@wdio/static-server-service": "^9.29.1",
        "@wireapp/core-crypto": "workspace:*",
        "chai": "^6.2.2",
        "dts-bundle-generator": "^9.5.1",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-wdio": "^9.29.1",
        "prettier": "^3.9.4",
        "tinybench": "^6.0.2",
        "ts-loader": "^9.6.2",
        "typedoc": "0.28.20",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.63.0",
        "uniffi-bindgen-react-native": "^0.31.0-3",
        "yarn": "^1.22.22"
    },
    "license": "GPL-3.0",
    "trustedDependencies": [
        "uniffi-bindgen-react-native"
    ]
}
