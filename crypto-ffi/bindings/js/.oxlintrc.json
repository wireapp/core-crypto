{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["typescript", "unicorn"],
    "env": {
        "builtin": true,
        "commonjs": true,
        "mocha": true
    },
    "options": {
        "typeAware": true
    },
    "globals": {
        "$": "readonly",
        "$$": "readonly",
        "browser": "readonly",
        "driver": "readonly",
        "expect": "readonly",
        "multiremotebrowser": "readonly",
        "multiRemoteBrowser": "readonly"
    },
    "ignorePatterns": [
        "packages/**/src/*.js",
        "packages/**/src*.d.ts",
        "packages/browser/src/autogenerated",
        "packages/browser/src/index.web.ts",
        "packages/native/src/autogenerated",
        "typedoc-ignore-warnings.cjs",
        "packages/core-crypto/dist",
        "eslint.config.js",
        "eslint.config.cjs",
        "eslint.config.mjs"
    ],
    "overrides": [
        {
            "files": ["**/*.ts", "**/*.tsx", "**/*.mts", "**/*.cts"],
            "rules": {
                "no-var": "error",
                "prefer-const": "error",
                "prefer-rest-params": "error",
                "prefer-spread": "error"
            }
        }
    ]
}
